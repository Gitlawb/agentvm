# agentvm profile: OpenCode
#
# Runs opencode (https://opencode.ai) — open-source TUI coding agent supporting
# Anthropic, OpenAI, OpenRouter, local models, and more.
#
# Each agent gets its own opencode state (seeded from the host's) so parallel
# agents don't share sessions or auth.
#
# Env vars (ANTHROPIC_API_KEY, OPENAI_API_KEY, OPENROUTER_API_KEY, etc.) are
# inherited from the host shell + ~/.agentvm/env.
#
# Usage:
#   agentvm spawn my-oc --profile opencode
#   agentvm spawn my-oc --profile opencode -- opencode --model anthropic/claude-sonnet-4-6

PROFILE_LABEL="OpenCode"

# Default command: opencode in TUI mode
PROFILE_CMD="opencode"

# Read-only: opencode is distributed as a single binary (typically in ~/.local/bin
# or via brew). Bun runtime path is included for source/dev installs.
PROFILE_RO_PATHS="${HOME}/.local/bin:${HOME}/.bun:${HOME}/.nvm"

# State dirs to seed into per-agent HOME (relative to $HOME).
# opencode keeps state under ~/.local/share/opencode and ~/.config/opencode.
PROFILE_STATE_DIRS=".local/share/opencode:.config/opencode"
