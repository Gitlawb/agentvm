# agentvm profile: OpenAI Codex
#
# Runs OpenAI Codex CLI in an isolated workspace with a per-agent HOME.
# The agent sees its own ~/.codex/ (seeded from the host's) so parallel agents
# don't share sessions, memories, or config.
#
# The Node.js runtime (~/.nvm/versions/node/...) is mounted read-only so the
# codex and node binaries are reachable inside the sandbox.
#
# Env vars (OPENAI_API_KEY, etc.) are inherited from the host shell and
# ~/.agentvm/env — no per-profile forwarding needed.
#
# Usage:
#   agentvm spawn my-codex --profile codex
#   agentvm spawn my-codex --profile codex -- codex -a never

PROFILE_LABEL="OpenAI Codex"

# Default command: codex in full-auto mode (agentvm provides outer sandboxing)
PROFILE_CMD="codex --full-auto"

# Read-only: Node.js runtime + codex binary (via nvm)
PROFILE_RO_PATHS="${HOME}/.nvm/versions/node/v22.13.0"

# State dirs to seed into per-agent HOME (relative to $HOME)
PROFILE_STATE_DIRS=".codex"

# Workspace setup script: pre-accepts the directory trust prompt
PROFILE_POST_CREATE_SCRIPT="$SCRIPT_DIR/profiles/setup-codex.sh"
