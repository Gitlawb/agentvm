# agentvm profile: OpenAI Codex
#
# Runs OpenAI Codex CLI in an isolated workspace.
# The agent gets full read-write access to its own workspace and to ~/.codex/
# (where Codex stores sessions, config, memories, and state).
#
# The entire Node.js runtime (~/.nvm/versions/node/...) is mounted read-only
# so the codex and node binaries are accessible inside the sandbox.
#
# Required env var: OPENAI_API_KEY
#
# Usage:
#   agentvm spawn my-codex --profile codex
#   agentvm spawn my-codex --profile codex -- codex -a never

PROFILE_LABEL="OpenAI Codex"

# Default command: run codex in full-auto mode (on-request approvals + workspace sandbox)
# Since agentvm already provides outer sandboxing, codex's internal sandbox is redundant
# but harmless. Use --full-auto for the smoothest automated experience.
PROFILE_CMD="codex --full-auto"

# Read-only: Node.js runtime + codex binary (via nvm)
# The whole node version dir is needed: bin/, lib/node_modules/, etc.
PROFILE_RO_PATHS="${HOME}/.nvm/versions/node/v22.13.0"

# Read-write: codex config/state dir (sessions, memories, history, config)
# Also include ~/.codex/config.toml (covered by ~/.codex above)
PROFILE_RW_PATHS="${HOME}/.codex"

# Env vars to forward into the sandbox
PROFILE_ENV_VARS="OPENAI_API_KEY:OPENAI_BASE_URL:OPENAI_ORG_ID"

# Workspace setup script: pre-accepts the directory trust prompt so codex starts
# at the interactive prompt without any dialogs.
PROFILE_POST_CREATE_SCRIPT="$SCRIPT_DIR/profiles/setup-codex.sh"
