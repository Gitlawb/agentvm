# agentvm profile: Claude Code
#
# Runs Claude Code (claude CLI) in an isolated workspace.
# The agent gets full read-write access to its own workspace and to ~/.claude/
# (where Claude Code stores session state, settings, and cache).
#
# Required env var: ANTHROPIC_API_KEY
#
# Usage:
#   agentvm spawn my-claude --profile claude-code
#   agentvm spawn my-claude --profile claude-code -- claude --model claude-opus-4-6

PROFILE_LABEL="Claude Code"

# Default command: run claude in non-interactive auto-approve mode
PROFILE_CMD="claude --dangerously-skip-permissions"

# Read-only: claude binary (symlink) + the actual versioned binary it points to
PROFILE_RO_PATHS="${HOME}/.local/bin/claude:${HOME}/.local/share/claude"

# Read-write: claude state/config dir (sessions, settings, cache, history)
# Also include ~/.claude.json where Claude Code records per-project trust acceptance
PROFILE_RW_PATHS="${HOME}/.claude:${HOME}/.claude.json"

# Env vars to forward into the sandbox
PROFILE_ENV_VARS="ANTHROPIC_API_KEY:ANTHROPIC_BASE_URL:CLAUDE_API_KEY"

# Workspace setup script: pre-creates .claude/settings.json (skips bypass-permissions
# warning) and pre-accepts the folder trust dialog so the agent starts cleanly.
PROFILE_POST_CREATE_SCRIPT="$SCRIPT_DIR/profiles/setup-claude-code.sh"
