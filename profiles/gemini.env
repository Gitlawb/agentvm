# agentvm profile: Google Gemini CLI
#
# Runs the Gemini CLI agent in an isolated workspace.
# The agent gets read-write access to its workspace and ~/.gemini/ (config, sessions).
#
# Required env var: GEMINI_API_KEY or GOOGLE_API_KEY
#
# Usage:
#   agentvm spawn my-gem --profile gemini
#   agentvm spawn my-gem --profile gemini --prompt /tmp/task.md

PROFILE_LABEL="Gemini CLI"

# Default command: run gemini in auto-yes mode
PROFILE_CMD="gemini --yolo"

# Read-only: the gemini binary and its node runtime (installed via npm/npx)
# We mount ~/.nvm and ~/.local/bin so the user's typical installs are reachable.
PROFILE_RO_PATHS="${HOME}/.local/bin:${HOME}/.nvm"

# Read-write: gemini stores session/cache state here
PROFILE_RW_PATHS="${HOME}/.gemini"

# Env vars to forward into the sandbox
PROFILE_ENV_VARS="GEMINI_API_KEY:GOOGLE_API_KEY:GOOGLE_CLOUD_PROJECT:GEMINI_MODEL"

PROFILE_POST_CREATE_SCRIPT="$SCRIPT_DIR/profiles/setup-gemini.sh"
