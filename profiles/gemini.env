# agentvm profile: Google Gemini CLI
#
# Runs the Gemini CLI agent in an isolated workspace with a per-agent HOME.
# The agent sees its own ~/.gemini/ (seeded from the host's) so parallel agents
# don't share sessions or config.
#
# Env vars (GEMINI_API_KEY, GOOGLE_API_KEY, etc.) are inherited from the host
# shell and ~/.agentvm/env — no per-profile forwarding needed.
#
# Usage:
#   agentvm spawn my-gem --profile gemini
#   agentvm spawn my-gem --profile gemini --prompt /tmp/task.md

PROFILE_LABEL="Gemini CLI"

# Default command: gemini in auto-yes mode
PROFILE_CMD="gemini --yolo"

# Read-only: the gemini binary and its node runtime
PROFILE_RO_PATHS="${HOME}/.local/bin:${HOME}/.nvm"

# State dirs to seed into per-agent HOME (relative to $HOME)
PROFILE_STATE_DIRS=".gemini"

PROFILE_POST_CREATE_SCRIPT="$SCRIPT_DIR/profiles/setup-gemini.sh"
