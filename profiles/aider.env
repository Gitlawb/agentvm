# agentvm profile: Aider
#
# Runs the Aider CLI in an isolated workspace. Aider connects to any LLM
# provider (Anthropic, OpenAI, etc.) based on which API key is present.
#
# Required env var: at least one of ANTHROPIC_API_KEY / OPENAI_API_KEY
#
# Usage:
#   agentvm spawn my-aider --profile aider
#   agentvm spawn my-aider --profile aider -- aider --model sonnet

PROFILE_LABEL="Aider"

# Default command: aider in yes-always mode, auto-commit disabled so agent
# commits stay explicit.
PROFILE_CMD="aider --yes-always --no-auto-commits"

# Read-only paths: typical pip install locations
PROFILE_RO_PATHS="${HOME}/.local/bin:${HOME}/.pyenv:${HOME}/.local/share/pipx"

# Read-write: aider's config + chat history
PROFILE_RW_PATHS="${HOME}/.aider"

# Forward keys Aider might need
PROFILE_ENV_VARS="ANTHROPIC_API_KEY:OPENAI_API_KEY:DEEPSEEK_API_KEY:GROQ_API_KEY:OPENROUTER_API_KEY:AIDER_MODEL"
