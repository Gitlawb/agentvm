# agentvm profile: Aider
#
# Runs the Aider CLI in an isolated workspace with a per-agent HOME.
# Aider connects to whichever provider its env vars point at (Anthropic, OpenAI,
# Deepseek, Groq, OpenRouter…). All inherited from the host shell + ~/.agentvm/env.
#
# Usage:
#   agentvm spawn my-aider --profile aider
#   agentvm spawn my-aider --profile aider -- aider --model sonnet

PROFILE_LABEL="Aider"

# Default command: aider in yes-always mode, auto-commit disabled so agent
# commits stay explicit.
PROFILE_CMD="aider --yes-always --no-auto-commits"

# Read-only paths: typical pip install locations
PROFILE_RO_PATHS="${HOME}/.local/bin:${HOME}/.pyenv:${HOME}/.local/share/pipx"

# State dirs to seed into per-agent HOME (relative to $HOME)
PROFILE_STATE_DIRS=".aider"
